# ===== AURAVIA 后端配置 =====
# 复制本文件为 .env 并按需修改。未配置 API_KEY 时自动进入 DEMO 演示模式（无需任何 key）。

# ---- LLM（OpenAI 兼容，任选其一）----
# OpenAI:         AURAVIA_BASE_URL=https://api.openai.com/v1
# DeepSeek:       AURAVIA_BASE_URL=https://api.deepseek.com/v1
# OpenRouter:     AURAVIA_BASE_URL=https://openrouter.ai/api/v1
# 本地 Ollama:    AURAVIA_BASE_URL=http://localhost:11434/v1
AURAVIA_BASE_URL=https://api.openai.com/v1

# 你的 API Key（留空 = DEMO 模式）
AURAVIA_API_KEY=

# 模型名（按上面平台填写，如 gpt-4o / deepseek-chat / llama3.1）
AURAVIA_MODEL=gpt-4o

# ---- 其它 ----
# 单次任务最大步数
AURAVIA_MAX_STEPS=25
# 单次回复最大 token
AURAVIA_MAX_TOKENS=1500
# 是否允许执行 Shell（公网部署建议设为 0）
AURAVIA_ALLOW_SHELL=1
# 强制 DEMO 模式（1=开，0=关）；不填则按是否有 key 自动判断
# AURAVIA_DEMO=0
